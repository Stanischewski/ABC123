# Vorlage — kopiere nach `.env` und passe die Werte an. `.env` ist gitignoriert.
#
# Postgres läuft in WSL (Ubuntu); Windows erreicht es über das
# localhost-Forwarding von WSL2. Dienst starten mit:
#   wsl sudo service postgresql start
#
# Ist DATABASE_URL nicht gesetzt, läuft der Server ohne Persistenz (im Speicher).
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/abc123

# Optional: Log-Level (z. B. info, debug, abc123_server=debug).
RUST_LOG=info
